# MongoDB connection string (local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/projet-elie

# Secret used to sign JWT access tokens (use a long random value in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Token lifetime
JWT_EXPIRES_IN=7d

# Local directory used to store uploaded files in development
UPLOAD_DIR=uploads

# Bootstrap superadmin credentials (used by the seed script)
SUPERADMIN_EMAIL=superadmin@portailcours.edu
SUPERADMIN_PASSWORD=Admin@1234
